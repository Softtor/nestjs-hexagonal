// Generic Integration Event Port pattern
// Each BC that emits integration events defines a port like this.
//
// Naming convention:
//   Token:     <BC>_INTEGRATION_EVENTS_TOKEN
//   Interface: <Bc>IntegrationEventsPort
//   Adapter:   <Bc>IntegrationEventsAdapter  (lives in the CONSUMING BC)

// ─────────────────────────────────────────────────────────────────────────────
// 1. PORT DEFINITION — lives in emitting BC: application/ports/
// ─────────────────────────────────────────────────────────────────────────────

export const MY_INTEGRATION_EVENTS_TOKEN = Symbol('MyIntegrationEvents');

export interface MyIntegrationEventsPort {
  // One method per integration event.
  // Payload MUST use primitive types only — no domain objects or VOs.
  entityCreated(payload: {
    id: string;
    organizationId: string;
    name: string;
    createdAt: string; // ISO string — not Date
  }): Promise<void>;

  entityUpdated(payload: {
    id: string;
    organizationId: string;
    changes: Record<string, unknown>;
  }): Promise<void>;
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. PUBLISHER HANDLER — lives in emitting BC: infrastructure/listeners/
// ─────────────────────────────────────────────────────────────────────────────

